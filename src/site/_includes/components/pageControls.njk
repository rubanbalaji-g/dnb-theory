<button class="filetree-toggle" aria-label="Toggle File Tree" onclick="document.body.classList.toggle('filetree-collapsed')">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="svg-icon"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
</button>

<button class="print-button" aria-label="Print Page" onclick="doPrint()">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="svg-icon"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect width="12" height="8" x="6" y="14"></rect></svg>
</button>

<script>
(function() {
    window.doPrint = function() {
        var content = document.querySelector('main.content');
        if (!content) { window.print(); return; }

        // Build URL
        var pagePath = window.location.pathname;
        var fullUrl = 'https://theory.pedianotes.in' + pagePath;
        var displayUrl = 'theory.pedianotes.in' + pagePath;

        // Logo URL
        var logoUrl = window.location.origin + '/logo.svg';

        // Format date/time in IST, 24-hour
        var now = new Date();
        var dateStr = now.toLocaleDateString('en-IN', {
            timeZone: 'Asia/Kolkata',
            day: '2-digit', month: 'short', year: 'numeric'
        });
        var timeStr = now.toLocaleTimeString('en-IN', {
            timeZone: 'Asia/Kolkata',
            hour: '2-digit', minute: '2-digit',
            hour12: false
        });

        var printWindow = window.open('', '_blank', 'width=900,height=700');

        printWindow.document.write(
            '<!DOCTYPE html><html lang="en"><head>' +
            '<meta charset="UTF-8">' +
            '<title>Print — PediaNotes</title>' +
            '<style>' +
            '* { box-sizing: border-box; margin: 0; padding: 0; }' +
            '@page { margin: 32mm 20mm 18mm; @bottom-center { content: "Page " counter(page) " of " counter(pages); font-family: Arial, sans-serif; font-size: 8pt; color: #666; } }' +
            'body { font-family: Georgia, "Times New Roman", serif; font-size: 12pt; line-height: 1.6; color: #000; background: #fff; padding: 32mm 20mm 18mm; }' +
            'h1, h2, h3, h4, h5, h6 { font-family: Arial, sans-serif; color: #000; margin: 1em 0 0.5em; page-break-after: avoid; }' +
            'h1 { font-size: 22pt; margin-bottom: 6px; }' +
            'h2 { font-size: 17pt; }' +
            'h3 { font-size: 14pt; }' +
            'p { margin: 0.5em 0 0.8em; }' +
            'ul, ol { margin: 0.5em 0 0.8em 1.5em; }' +
            'li { margin-bottom: 0.3em; }' +
            'table { border-collapse: collapse; width: 100%; margin: 1em 0; font-size: 10pt; }' +
            'th, td { border: 1px solid #999; padding: 5px 8px; text-align: left; }' +
            'th { background: #eee; font-weight: bold; }' +
            'code { font-family: Consolas, monospace; background: #f0f0f0; padding: 1px 4px; border-radius: 3px; font-size: 10pt; }' +
            'pre { background: #f4f4f4; border: 1px solid #ccc; padding: 10px; overflow-wrap: break-word; white-space: pre-wrap; margin: 1em 0; }' +
            'pre code { background: none; padding: 0; }' +
            'blockquote { border-left: 3px solid #999; padding-left: 12px; color: #444; margin: 1em 0; }' +
            'a { color: #1a0dab; text-decoration: underline; }' +
            'img { max-width: 100%; height: auto; }' +
            'hr { border: none; border-top: 1px solid #ccc; margin: 1.5em 0; }' +
            '.callout { border: 1px solid #ccc; border-left: 4px solid #666; padding: 8px 12px; margin: 1em 0; background: #fafafa; }' +
            '.tag, .external-link::after, .filetree-toggle, .print-button, .graph, .backlinks, .toc { display: none !important; }' +

            /* Header — fixed, repeats on every printed page */
            '.print-page-header {' +
            '  position: fixed; top: 0; left: 0; right: 0;' +
            '  height: 28mm;' +
            '  display: flex; align-items: center; justify-content: space-between;' +
            '  background: #fff;' +
            '  padding: 4px 20mm;' +
            '  gap: 20px;' +
            '}' +

            /* Left: logo + site name */
            '.print-header-left {' +
            '  display: flex; align-items: center; gap: 10px; flex-shrink: 0;' +
            '}' +
            '.print-header-left img { height: 50px; width: auto; }' +
            '.print-header-left .site-name { font-family: Arial, sans-serif; font-size: 18pt; font-weight: bold; color: #1a3a5c; }' +

            /* Right: 3 small info lines */
            '.print-header-right {' +
            '  display: flex; flex-direction: column; align-items: flex-end; justify-content: center;' +
            '  text-align: right; font-family: Arial, sans-serif; gap: 1px;' +
            '  min-width: 0; overflow: hidden;' +
            '}' +
            '.print-header-right .info-link {' +
            '  font-size: 7.5pt; color: #1a0dab; white-space: nowrap; overflow: hidden; text-overflow: clip; max-width: 55mm;' +
            '}' +
            '.print-header-right .info-link a { color: #1a0dab; text-decoration: underline; }' +
            '.print-header-right .info-datetime { font-size: 8pt; color: #333; white-space: nowrap; }' +
            '.print-header-right .info-author { font-size: 8pt; color: #333; white-space: nowrap; }' +

            '@page { margin: 15mm 20mm 20mm; @bottom-center { content: "Page " counter(page) " of " counter(pages); font-family: Arial, sans-serif; font-size: 8.5pt; color: #666; } }' +
            '@media print { body { padding: 0; margin: 0; } }' +
            '.header-space { height: 28mm; }' +
            '.content-table { width: 100%; border: none; border-collapse: collapse; }' +
            '.content-table td { border: none !important; padding: 0 !important; background: transparent; }' +
            '</style>' +
            '</head>' +
            '<body>' +

            '<div class="print-page-header">' +
              '<div class="print-header-left">' +
                '<img src="' + logoUrl + '" alt="PediaNotes logo">' +
                '<span class="site-name"><span style="color: blue;">PediaNotes</span><span style="color: red;">.in</span></span>' +
              '</div>' +
              '<div class="print-header-right">' +
                '<div class="info-link"><a href="' + fullUrl + '">' + displayUrl + '</a></div>' +
                '<div class="info-datetime">' + dateStr + ' &nbsp; ' + timeStr + ' IST</div>' +
                '<div class="info-author">Author: Dr. Rubanbalaji G</div>' +
              '</div>' +
            '</div>' +

            '<table class="content-table">' +
              '<thead><tr><td><div class="header-space">&nbsp;</div></td></tr></thead>' +
              '<tbody><tr><td>' +
                content.innerHTML +
              '</td></tr></tbody>' +
            '</table>' +

            '</body></html>'
        );
        printWindow.document.close();

        printWindow.onload = function() {
            printWindow.focus();
            printWindow.print();
            printWindow.onafterprint = function() { printWindow.close(); };
        };
    };
})();
</script>
