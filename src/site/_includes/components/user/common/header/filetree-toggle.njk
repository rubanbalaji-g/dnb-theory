<button id="filetree-toggle" aria-label="Toggle File Tree" class="custom-toggle-btn">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="9" x2="9" y1="3" y2="21"/></svg>
</button>

<style>
    .custom-toggle-btn {
        position: fixed;
        top: 15px;
        left: 15px;
        z-index: 1001; /* Above the filetree */
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        background: var(--background-primary);
        border: 1px solid var(--outline-color);
        border-radius: 6px;
        color: var(--text-muted);
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .custom-toggle-btn:hover {
        color: var(--text-normal);
        background: var(--background-modifier-hover);
    }

    /* Target the actual container and the layout variable */
    .filetree-hidden-state .filetree-sidebar {
        display: none !important;
        width: 0 !important;
    }

    .filetree-hidden-state {
        --dg-filetree-width: 0px !important;
    }
    
    /* Ensure the toggle button stays visible when sidebar is gone */
    .filetree-hidden-state .custom-toggle-btn {
        left: 15px;
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const btn = document.getElementById('filetree-toggle');
    const htmlEl = document.documentElement; // This is the <html> tag

    // Load saved state
    if (localStorage.getItem('filetree-collapsed') === 'true') {
        htmlEl.classList.add('filetree-hidden-state');
    }

    btn.addEventListener('click', () => {
        const isHidden = htmlEl.classList.toggle('filetree-hidden-state');
        localStorage.setItem('filetree-collapsed', isHidden);
        
        // Force a layout refresh for the graph/content
        window.dispatchEvent(new Event('resize'));
    });
});
</script>
