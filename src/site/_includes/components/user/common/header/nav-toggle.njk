<button id="nav-toggle" style="cursor: pointer; padding: 5px 10px; margin: 10px;">
    ☰ Menu
</button>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const toggleBtn = document.getElementById('nav-toggle');
    // The default ole.dev navbar class is usually .filetree-sidebar
    const navBar = document.querySelector('.filetree-sidebar');

    if (toggleBtn && navBar) {
        toggleBtn.addEventListener('click', function() {
            if (navBar.style.display === 'none') {
                navBar.style.display = 'block';
            } else {
                navBar.style.display = 'none';
            }
        });
    }
});
</script>
