<style>
    /* Footer Container */
    .site-footer {
        margin-top: 4rem;
        padding: 2rem 1rem;
        text-align: center;
        border-top: 1px solid var(--text-muted, #ccc);
        color: var(--text-muted, #888);
        font-family: sans-serif;
    }
    
    /* Garden Note */
    .garden-note {
        font-style: italic;
        opacity: 0.9;
        margin-bottom: 1rem;
        color: var(--text-normal, #333);
    }

    /* Single Line Row styling */
    .footer-row {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        font-weight: 500;
        margin-bottom: 1.5rem; /* Space between links and disclaimer */
    }

    /* Separator dots */
    .separator {
        opacity: 0.5;
    }

    /* Link Styling (Things 3 Teal) */
    .footer-row a {
        color: #00B39F !important; 
        text-decoration: none;
        opacity: 0.9;
        transition: opacity 0.2s;
    }
    
    .footer-row a:hover {
        opacity: 1;
        text-decoration: underline;
    }

    /* Disclaimer (New Settings) */
    .disclaimer {
        font-size: 0.7em;  /* Made smaller */
        opacity: 0.6;      /* Slightly more faded to be unobtrusive */
        line-height: 1.5;  /* Good spacing for readability */
        max-width: 650px;  /* Keeps the text from getting too wide on desktop */
        margin-left: auto;
        margin-right: auto;
    }

    .graphviz {
        display: flex;
        justify-content: center;
        margin: 1rem 0;
        overflow-x: auto;
    }
    .graphviz.raw {
        display: none;
    }
    .graphviz svg {
        max-width: 100%;
        height: auto;
    }
</style>

<script type="module">
    import { Graphviz } from "https://cdn.jsdelivr.net/npm/@hpcc-js/wasm/dist/index.js";

    async function renderGraphviz() {
        const elements = document.querySelectorAll(".graphviz");
        if (elements.length === 0) return;

        // Hide raw content immediately
        elements.forEach(el => el.classList.add('raw'));

        try {
            const graphviz = await Graphviz.load();
            for (const el of elements) {
                const dot = el.textContent;
                try {
                    const svg = graphviz.dot(dot);
                    el.innerHTML = svg;
                    el.classList.remove('raw');
                } catch (e) {
                    console.error("Graphviz Error:", e);
                    el.innerHTML = `<pre style="color: red;">${e.message}</pre>`;
                    el.classList.remove('raw');
                }
            }
        } catch (e) {
            console.error("Failed to load Graphviz WASM:", e);
        }
    }

    // Run on load
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', renderGraphviz);
    } else {
        renderGraphviz();
    }
</script>



