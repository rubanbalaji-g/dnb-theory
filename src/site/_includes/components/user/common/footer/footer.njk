        font-weight: bold;
        animation: color-glow 8s infinite alternate ease-in-out;
        transition: color 0.5s;
    }

    @keyframes color-glow {
        0% { color: var(--h1-color); text-shadow: 0 0 5px rgba(var(--h1-color), 0.2); }
        50% { color: var(--h2-color); text-shadow: 0 0 10px rgba(var(--h2-color), 0.3); }
        100% { color: var(--h3-color); text-shadow: 0 0 5px rgba(var(--h3-color), 0.2); }
    }

    /* Link Styling (Branded Pink) */
