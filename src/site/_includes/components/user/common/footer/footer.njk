    /* Single Line Row styling */
    .footer-row {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
        font-weight: 500;
        margin-bottom: 2rem;
    }

    /* Copyright with ever-changing colors */
