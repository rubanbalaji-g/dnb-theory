<!DOCTYPE html>
<html lang="{{ meta.mainLanguage }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 – Page Not Found | PediaNotes</title>

    <link href="/styles/digital-garden-base.css" rel="stylesheet">

    {%- if meta.themeStyle %}
        <link href="/styles/obsidian-base.css" rel="stylesheet">
        <link href="{{ meta.themeStyle }}" rel="stylesheet">
    {% else %}
        <link href="/styles/style.css" rel="stylesheet">
    {% endif %}

    <link href="/styles/custom-style.css" rel="stylesheet">

    <style>
        html, body {
            height: 100%;
            margin: 0;
        }

        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            background: linear-gradient(135deg, #eef6ff 0%, #f8fbff 100%);
        }

        .card {
            background: white;
            max-width: 640px;
            width: 90%;
            padding: 3rem 2.5rem;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
            text-align: center;
            animation: fadeIn 0.6s ease-out;
        }

        .icon {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .error-code {
            font-size: 5rem;
            font-weight: 700;
            letter-spacing: -2px;
            margin: 0;
            color: #1e3a8a;
        }

        .title {
            font-size: 1.6rem;
            margin: 1rem 0;
            font-weight: 600;
        }

        .description {
            font-size: 1.05rem;
            opacity: 0.75;
            margin-bottom: 2rem;
            line-height: 1.6;
        }

        .actions a {
            display: inline-block;
            margin: 0.4rem;
            padding: 0.7rem 1.4rem;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.2s ease;
        }

        .primary-btn {
            background: #2563eb;
            color: white;
        }

        .primary-btn:hover {
            background: #1e40af;
            transform: translateY(-2px);
        }

        .secondary-btn {
            border: 1px solid #cbd5e1;
            color: #1e293b;
        }

        .secondary-btn:hover {
            background: #f1f5f9;
            transform: translateY(-2px);
        }

        .footer {
            margin-top: 2.5rem;
            font-size: 0.85rem;
            opacity: 0.5;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(15px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Dark mode compatibility */
        body.theme-dark {
            background: linear-gradient(135deg, #0f172a 0%, #111827 100%);
        }

        body.theme-dark .card {
            background: #1e293b;
            color: #e2e8f0;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
        }

        body.theme-dark .secondary-btn {
            border-color: #334155;
            color: #e2e8f0;
        }

        body.theme-dark .secondary-btn:hover {
            background: #334155;
        }
    </style>
</head>

<body class="theme-{{ meta.baseTheme }}">
    <div class="card">

        <div class="icon">🩺</div>

        <h1 class="error-code">404</h1>

        <div class="title">
            Page Not Found
        </div>

        <div class="description">
            The clinical note you’re looking for does not exist,
            may have been relocated, or is not publicly accessible.
        </div>

        <div class="actions">
            <a href="/" class="primary-btn">Return to Home</a>
            <a href="/search" class="secondary-btn">Search Notes</a>
        </div>

        <div class="footer">
            PediaNotes — Structured Pediatric Learning
        </div>

    </div>
</body>
</html>
