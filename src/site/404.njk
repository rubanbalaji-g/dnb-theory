<!DOCTYPE html>
<html lang="{{ meta.mainLanguage }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 – Page Not Found | PediaNotes</title>

    <link href="/styles/digital-garden-base.css" rel="stylesheet">

    {%- if meta.themeStyle %}
        <link href="/styles/obsidian-base.css" rel="stylesheet">
        <link href="{{ meta.themeStyle }}" rel="stylesheet">
    {% else %}
        <link href="/styles/style.css" rel="stylesheet">
    {% endif %}

    <link href="/styles/custom-style.css" rel="stylesheet">

    <style>
        html, body {
            height: 100%;
            margin: 0;
        }

        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        .error-wrapper {
            text-align: center;
            max-width: 600px;
            padding: 2rem;
        }

        .error-code {
            font-size: 5rem;
            font-weight: 700;
            margin-bottom: 1rem;
        }

        .error-title {
            font-size: 1.8rem;
            margin-bottom: 1rem;
        }

        .error-description {
            font-size: 1.1rem;
            opacity: 0.8;
            margin-bottom: 2rem;
        }

        .error-actions a {
            display: inline-block;
            margin: 0.5rem;
            padding: 0.6rem 1.2rem;
            border-radius: 6px;
            text-decoration: none;
            font-weight: 500;
        }

        .primary-btn {
            background-color: #2563eb;
            color: white;
        }

        .secondary-btn {
            border: 1px solid currentColor;
        }

        .footer-note {
            margin-top: 2rem;
            font-size: 0.9rem;
            opacity: 0.6;
        }
    </style>
</head>

<body class="theme-{{ meta.baseTheme }}">
    <div class="error-wrapper">

        <div style="font-size:3rem;">🩺</div>

        <div class="error-code">404</div>

        <div class="error-title">
            Page Not Found
        </div>

        <div class="error-description">
            The note you’re looking for doesn’t exist,
            may have been moved, or is not publicly available.
        </div>

        <div class="error-actions">
            <a href="/" class="primary-btn">Return to Home</a>
            <a href="/search" class="secondary-btn">Search Notes</a>
        </div>

        <div class="footer-note">
            PediaNotes – Structured Pediatric Learning
        </div>

    </div>
</body>
</html>
