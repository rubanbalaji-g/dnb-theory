SITE_NAME_HEADER=Pedia Notes
SITE_MAIN_LANGUAGE=en
SITE_BASE_URL=https://pedianotes.in/
SHOW_CREATED_TIMESTAMP=true
TIMESTAMP_FORMAT=dd MMM yyyy hh:mm
SHOW_UPDATED_TIMESTAMP=true
NOTE_ICON_DEFAULT=
NOTE_ICON_TITLE=false
NOTE_ICON_FILETREE=false
NOTE_ICON_INTERNAL_LINKS=false
NOTE_ICON_BACK_LINKS=false
STYLE_SETTINGS_CSS=body.css-settings-manager { --h1-text-align: center; --h1-text-transform: capitalize; --h2-text-transform: capitalize; --h4-size: 1.24em; --h4-text-transform: capitalize; --h3-text-transform: capitalize; --h5-text-transform: capitalize; --h6-text-transform: capitalize; --h1-style: underline; --h1-border-width: 4px; } body.theme-light.css-settings-manager { } body.theme-dark.css-settings-manager { --h1-bg-color: hsla(0,0%,0%,0); --h2-color: hsl(32,100%,50%); --h1-color: hsl(32,100%,50%); }
STYLE_SETTINGS_BODY_CLASSES=theme-dark mod-windows is-frameless is-hidden-frameless obsidian-app show-inline-title show-ribbon show-view-header css-settings-manager is-maximized highlightr-realistic anp-td-none is-focused ribbon-default editor-bg-default file-header-default sb-default sb-item-default h1-vt-align-center
USE_FULL_RESOLUTION_IMAGES=true
THEME=https://raw.githubusercontent.com/colineckert/obsidian-things/HEAD/theme.css
BASE_THEME=dark
dgHomeLink=true
dgPassFrontmatter=false
dgShowBacklinks=true
dgShowLocalGraph=true
dgShowInlineTitle=true
dgShowFileTree=false
dgEnableSearch=true
dgShowToc=true
dgLinkPreview=true
dgShowTags=true