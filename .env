SITE_NAME_HEADER=Pedia Notes
SITE_MAIN_LANGUAGE=en
SITE_BASE_URL=https://pedianotes.in/
SHOW_CREATED_TIMESTAMP=true
TIMESTAMP_FORMAT=dd MMM yyyy hh:mm
SHOW_UPDATED_TIMESTAMP=true
NOTE_ICON_DEFAULT=
NOTE_ICON_TITLE=false
NOTE_ICON_FILETREE=false
NOTE_ICON_INTERNAL_LINKS=false
NOTE_ICON_BACK_LINKS=false
STYLE_SETTINGS_CSS=body.css-settings-manager { --h1-variant: all-small-caps; --h1-style: italic; --h2-variant: all-small-caps; --h2-style: italic; --h1-size: 2em; --h2-size: 1.3em; --h3-variant: all-small-caps; --h3-size: 1.15em; --h4-size: 1.05em; --h4-variant: all-small-caps; --h4-style: italic; --h5-size: 1em; --h5-variant: all-small-caps; --h5-style: italic; --h6-variant: all-small-caps; --h6-style: italic; --h6-size: 0.9em; } body.theme-light.css-settings-manager { } body.theme-dark.css-settings-manager { --h1-color: #FF632F; --h2-color: #B7FF39; --h3-color: #3AFFD0; --h4-color: #7682FF; --h5-color: #D27CFF; --h6-color: #FF73FC; }
STYLE_SETTINGS_BODY_CLASSES=theme-dark mod-windows is-frameless is-hidden-frameless obsidian-app show-inline-title show-ribbon show-view-header css-settings-manager is-maximized highlightr-realistic anp-td-none callouts-default trim-cols h1-l checkbox-circle pdf-seamless-on pdf-invert-dark pdf-blend-light sidebar-tabs-default tab-names-off vault-profile-default ribbon-hidden maximize-tables-off tabs-default tab-stack-top minimal-tab-title-hover default is-focused
USE_FULL_RESOLUTION_IMAGES=true
THEME=https://raw.githubusercontent.com/kepano/obsidian-minimal/HEAD/theme.css
BASE_THEME=dark
dgHomeLink=true
dgPassFrontmatter=false
dgShowBacklinks=true
dgShowLocalGraph=true
dgShowInlineTitle=true
dgShowFileTree=false
dgEnableSearch=true
dgShowToc=true
dgLinkPreview=true
dgShowTags=true