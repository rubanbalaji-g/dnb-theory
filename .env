SITE_NAME_HEADER=Pedia Notes
SITE_MAIN_LANGUAGE=en
SITE_BASE_URL=https://pedianotes.in/
SHOW_CREATED_TIMESTAMP=true
TIMESTAMP_FORMAT=dd MMM yyyy hh:mm
SHOW_UPDATED_TIMESTAMP=true
NOTE_ICON_DEFAULT=
NOTE_ICON_TITLE=false
NOTE_ICON_FILETREE=false
NOTE_ICON_INTERNAL_LINKS=false
NOTE_ICON_BACK_LINKS=false
STYLE_SETTINGS_CSS=body.css-settings-manager { --h3-size: 1.2em; --h4-size: 1.1em; --h4-weight: 500; --h5-size: 1.05em; --h5-weight: 500; --h6-weight: 400; --h6-size: 1em; } body.theme-light.css-settings-manager { } body.theme-dark.css-settings-manager { }
STYLE_SETTINGS_BODY_CLASSES=theme-dark mod-windows is-frameless is-hidden-frameless obsidian-app show-inline-title show-ribbon show-view-header css-settings-manager is-maximized highlightr-realistic anp-td-none ctp-rosepine-light ctp-frappe ctp-accent-lavender anuppuccin-accent-toggle anp-no-highlight anp-callout-vanilla-normal anp-latex-inline-text anp-latex-block-text anp-hide-external-link-icon anp-header-color-toggle anp-header-margin-toggle anp-header-divider-color-toggle anp-h1-red anp-h1-divider anp-h2-peach anp-h3-green anp-h4-teal anp-h5-lavender anp-h6-mauve anp-bold-red anp-italic-green anp-highlight-yellow anp-default-rainbow anp-default-tab is-focused
USE_FULL_RESOLUTION_IMAGES=true
THEME=https://raw.githubusercontent.com/AnubisNekhet/AnuPpuccin/HEAD/theme.css
BASE_THEME=dark
dgHomeLink=true
dgPassFrontmatter=false
dgShowBacklinks=true
dgShowLocalGraph=true
dgShowInlineTitle=true
dgShowFileTree=false
dgEnableSearch=true
dgShowToc=true
dgLinkPreview=true
dgShowTags=true