SITE_NAME_HEADER=PediaNotes
SITE_MAIN_LANGUAGE=en
SITE_BASE_URL=https://pedianotes.in/
SHOW_CREATED_TIMESTAMP=true
TIMESTAMP_FORMAT=dd MMM yyyy hh:mm
SHOW_UPDATED_TIMESTAMP=true
NOTE_ICON_DEFAULT=
NOTE_ICON_TITLE=false
NOTE_ICON_FILETREE=false
NOTE_ICON_INTERNAL_LINKS=false
NOTE_ICON_BACK_LINKS=false
STYLE_SETTINGS_CSS=body.css-settings-manager { --em-color: #FFFFFF; --strong-color: #FFFFFF; --h3-color: #B3FFB9; --h4-color: #F1B8B1; --h5-color: #CAD177; --h6-color: #C48CFF; --h1-color: #C0E8F4; --h1-color: #1E3A8A; --h2-color: #E8D5EC; --h2-color: #581C87; --h3-color: #EED6D2; --h3-color: #9D174D; --h4-color: #D8A69E; --h4-color: #931616; --h5-color: #E6BFA3; --h5-color: #C2410C; --h6-color: #D7EED9; --h6-color: #2C3E50; --em-color: #C0E8F4; --em-color: #1E3A8A; --strong-color: #D8A69E; --strong-color: #931616; } body.theme-light.css-settings-manager { } body.theme-dark.css-settings-manager { }
STYLE_SETTINGS_BODY_CLASSES=mod-linux is-frameless obsidian-app styled-scrollbars show-inline-title is-floating-nav auto-full-screen show-ribbon show-view-header is-maximized highlightr-realistic css-settings-manager theme-dark is-focused mobile-black-background default-font-color h2-no-underline
USE_FULL_RESOLUTION_IMAGES=true
THEME=https://raw.githubusercontent.com/diegoeis/obsidianotion/HEAD/theme.css
BASE_THEME=dark
dgHomeLink=true
dgPassFrontmatter=true
dgShowBacklinks=true
dgShowLocalGraph=false
dgShowInlineTitle=true
dgShowFileTree=true
dgEnableSearch=true
dgShowToc=true
dgLinkPreview=true
dgShowTags=true