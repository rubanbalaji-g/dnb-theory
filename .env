SITE_NAME_HEADER=PediaNotes
SITE_MAIN_LANGUAGE=en
SITE_BASE_URL=https://pedianotes.in/
SHOW_CREATED_TIMESTAMP=true
TIMESTAMP_FORMAT=dd MMM yyyy hh:mm
SHOW_UPDATED_TIMESTAMP=true
NOTE_ICON_DEFAULT=
NOTE_ICON_TITLE=false
NOTE_ICON_FILETREE=false
NOTE_ICON_INTERNAL_LINKS=false
NOTE_ICON_BACK_LINKS=false
STYLE_SETTINGS_CSS=body.css-settings-manager { --h1-style: italic; --h1-weight: 800; --h3-color: hsl(88.42,76%,85.29%); --h4-color: hsl(62.07,100%,88.63%); --h5-color: hsl(0,100%,90.2%); --h6-color: hsl(0,94.12%,93.33%); --h6-variant: all-small-caps; --h5-variant: all-small-caps; --h4-variant: all-small-caps; --h3-variant: all-small-caps; --h2-variant: all-small-caps; --h1-variant: all-small-caps; --h5-style: italic; --h6-style: italic; --h4-style: italic; --h3-style: italic; --h2-style: italic; --h2-color: hsl(103.76,100%,83.33%); --active-line-accent: transparent; --tag-radius: 2em; --tag-border-width: 1px; --h1-color: hsl(160,34.62%,59.22%); --font-editor-theme: Roboto; } body.theme-light.css-settings-manager { --tag-color: rgb(255,153,0); --tag-background: rgb(0,0,0); --tag-color-hover: rgb(255,255,255); } body.theme-dark.css-settings-manager { --tag-background: rgb(255,153,0); --tag-color: rgb(0,0,0); --tag-color-hover: rgb(255,255,255); }
STYLE_SETTINGS_BODY_CLASSES=theme-dark mod-windows is-frameless is-hidden-frameless obsidian-app styled-scrollbars show-inline-title is-floating-nav auto-full-screen show-ribbon show-view-header is-maximized highlightr-realistic css-settings-manager sanctum-default-light sanctum-default-dark # h2-line default-marker-odd default-marker-even table-column-border is-focused
USE_FULL_RESOLUTION_IMAGES=true
THEME=https://raw.githubusercontent.com/MrParalloid/obsidian-things/HEAD/theme.css
BASE_THEME=dark
dgHomeLink=true
dgPassFrontmatter=true
dgShowBacklinks=true
dgShowLocalGraph=true
dgShowInlineTitle=true
dgShowFileTree=true
dgEnableSearch=true
dgShowToc=true
dgLinkPreview=true
dgShowTags=true